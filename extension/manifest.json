{
  "manifest_version": 3,
  "name": "ReadyCode ImageKit",
  "version": "1.0.30",
  "description": "Free BYOK AI image studio. Generate from a prompt or respin any image with your own AI provider key. Saves to your ReadyCode library.",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "contextMenus",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://readycode.ai/*",
    "https://*.readycode.ai/*",
    "https://gmlnipblxehgadagxakt.supabase.co/*",
    "https://www.youtube.com/*",
    "https://www.tiktok.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "action": {
    "default_title": "ReadyCode ImageKit",
    "default_icon": {
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
